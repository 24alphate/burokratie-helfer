# ── Local Development ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./burokratie.db
OCR_BACKEND=mock
TRANSLATION_BACKEND=mock
# Allowed frontend origins, comma-separated. Unset/empty = allow ALL origins
# (a startup warning is logged). Set this in production.
CORS_ORIGINS_RAW=http://localhost:3000
MAX_UPLOAD_SIZE_MB=10

# Signing key for stateless pdf_token. REQUIRED for stable behavior — without it
# a random key is generated per process and tokens break across restarts/workers.
# Generate one with: python -c "import os;print(os.urandom(32).hex())"
SECRET_KEY=change-me-to-a-long-random-hex-string

# Anthropic API key — primary AI layer (question translation + Claude Vision OCR).
# Leave as the REPLACE placeholder to run without AI (deterministic table only).
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_API_KEY

# Optional Level-2 AcroForm enrichment: label widgets + group sibling checkboxes
# into one question. "off" (default) | "claude" (needs ANTHROPIC_API_KEY) |
# "gemini" (needs GEMINI_API_KEY). Safe to leave off; enables nicer choice UIs.
# VISION_BACKEND=claude

# ── Railway Production ─────────────────────────────────────────────
# DATABASE_URL is set automatically by Railway when you add a PostgreSQL plugin.
# Example: postgresql://postgres:password@containers-us-west.railway.app:5432/railway
#
# Set these manually in Railway environment variables:
# CORS_ORIGINS_RAW=https://your-app.vercel.app,https://your-custom-domain.com
# OCR_BACKEND=mock
# TRANSLATION_BACKEND=mock
